// Example test config - requires a minimal set of input data (to be hosted in marchoeppner/nf-testdata)
params {

	input = "https://raw.githubusercontent.com/bio-raum/gabi/main/assets/test/samples_ont.csv"
	run_name = "pipeline_test"
	random_seed = 12345
	max_coverage = 150
	medaka_model = "r104_e81_sup_g610" //documented in https://github.com/rrwick/Perfect-bacterial-genome-tutorial/wiki/Tutorial-%28easy%29
	
}
process {
	resourceLimits = [ cpus: 6, memory: 25.GB, time: 72.h ]
}